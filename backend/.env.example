# Claude (Anthropic) API key — https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-...

# Groq API key (Whisper transcription) — https://console.groq.com/
GROQ_API_KEY=gsk_...

# Twilio credentials — https://www.twilio.com/console
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Public base URL Twilio uses for webhooks (ngrok URL in dev, production domain in prod)
BASE_URL=https://your-subdomain.ngrok-free.app

# Optional — displayed in AI prompts and UI labels
COMPANY_NAME=Your Company Name

# Optional — PostgreSQL connection string (in-memory fallback used if omitted)
# DATABASE_URL=postgresql://user:password@localhost:5432/hrdb
